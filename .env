# Pinarr - Configuration minimale
# Modifiez ces valeurs selon vos besoins

# ===========================================
# OBLIGATOIRE : Changez le mot de passe admin
# ===========================================
ADMIN_PASSWORD=admin123

# ===========================================
# OPTIONNEL : Configuration des ports
# ===========================================
# Port de l'interface web (défaut: 8908)
# PORT=8908

# Port API direct - compatibilité anciennes versions (défaut: 9994)
# BACKEND_PORT=9994

# ===========================================
# OPTIONNEL : Compte admin
# ===========================================
# Nom d'utilisateur admin (défaut: admin)
# ADMIN_USERNAME=admin

# ===========================================
# OPTIONNEL : Sécurité
# ===========================================
# Clé secrète pour JWT - laissez vide pour génération auto
# SECRET_KEY=

# ===========================================
# NOTES
# ===========================================
# - Les données sont conservées dans les dossiers ./data et ./uploads
# - La clé JWT est générée automatiquement si non définie
# - Les ports par défaut fonctionnent dans la plupart des cas
# - Modifiez ADMIN_PASSWORD pour la sécurité !